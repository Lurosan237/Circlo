# Circlo Safety Backend Environment Variables
# Copy this file to .env and update values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Circlo Safety API
DEBUG=false
API_V1_PREFIX=/api/v1
ENVIRONMENT=development  # development, staging, production

# Server settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =============================================================================
# DATABASE SETTINGS
# Requirements: 7.2 - Row-Level Security and connection pooling
# =============================================================================
DATABASE_URL=postgresql+asyncpg://circlo:circlo_secret@localhost:5432/circlo_db

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# =============================================================================
# JWT AUTHENTICATION
# Requirements: 1.2 - JWT token with 24-hour expiry
# =============================================================================
# IMPORTANT: Generate a secure random key for production!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# RATE LIMITING
# Requirements: 1.4, 10.4 - Rate limiting to prevent abuse
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW_MINUTES=1

# =============================================================================
# ENCRYPTION
# Requirements: 5.1, 7.1 - End-to-end encryption and PII hashing
# =============================================================================
# IMPORTANT: Generate secure random keys for production!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-32-byte-encryption-key-here
NOTIFICATION_KEY=your-notification-encryption-key

# =============================================================================
# FIREBASE (Push Notifications)
# Requirements: 8.1 - Push notifications via Firebase Cloud Messaging
# =============================================================================
FIREBASE_CREDENTIALS_PATH=

# =============================================================================
# CORS SETTINGS
# =============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# =============================================================================
# SECURITY HEADERS
# Requirements: 7.1 - Security hardening
# =============================================================================
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_CONTENT_TYPE_NOSNIFF=true
SECURITY_FRAME_DENY=true
SECURITY_XSS_PROTECTION=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text
LOG_FILE=  # Optional: path to log file

# =============================================================================
# MONITORING
# =============================================================================
ENABLE_METRICS=true
METRICS_PATH=/metrics

# =============================================================================
# DATA RETENTION
# Requirements: 5.5, 7.4 - Automatic deletion after 90 days
# =============================================================================
DATA_RETENTION_DAYS=90
CLEANUP_BATCH_SIZE=1000
